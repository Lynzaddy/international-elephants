# DEFAULT WORKPRESS GITIGNORE FOR LYNZADDY PROJECTS #

# ─── WordPress Core ───────────────────────────────────
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
index.php
license.txt
readme.html

# ─── Uploads, Plugins & Upgrades ──────────────────────
/uploads/
/plugins/
/upgrade/

# ─── Themes (keep only your child theme) ──────────────
/themes/*
!/themes/hello-elementor-child/

# ─── Environment & Config ─────────────────────────────
wp-config.php
wp-config-sample.php
.env
*.env.*

# ─── Cache & Generated Files ──────────────────────────
cache/
advanced-cache.php
object-cache.php
wp-cache-config.php

# ─── OS & Editor Noise ────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.bak
*.swp
.idea/
.vscode/